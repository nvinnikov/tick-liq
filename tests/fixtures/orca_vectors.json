      "expected_amount_a": 0,
      "expected_amount_b": 0,
      "tolerance_abs": 0
    },
    {
      "description": "A2: below range -> amount_b == 0, amount_a > 0",
      "liquidity": 1000000000,
      "tick_current": -200,
      "tick_lower": -100,
      "tick_upper": 100,
      "expected_amount_a": 9999541,
      "expected_amount_b": 0,
      "tolerance_abs": 50
    },
    {
      "description": "A3: above range -> amount_a == 0, amount_b > 0",
      "liquidity": 1000000000,
      "tick_current": 200,
      "tick_lower": -100,
      "tick_upper": 100,
      "expected_amount_a": 0,
      "expected_amount_b": 9999541,
      "tolerance_abs": 50
    },
    {
      "description": "A4: in range, symmetric about tick 0 -> amount_a == amount_b (modulo Q64.64 rounding)",
      "liquidity": 1000000000,
      "tick_current": 0,
      "tick_lower": -100,
      "tick_upper": 100,
      "expected_amount_a": 4987272,
      "expected_amount_b": 4987272,
      "tolerance_abs": 50
    },
    {
      "description": "A5: tight in-range near tick 0",
      "liquidity": 1000000000,
      "tick_current": 0,
      "tick_lower": -10,
      "tick_upper": 10,
      "expected_amount_a": 499850,
      "expected_amount_b": 499850,
      "tolerance_abs": 20
    },
    {
      "description": "A6: price exactly at lower bound (in-range branch) -> amount_b == 0",
      "liquidity": 1000000000,
      "tick_current": -100,
      "tick_lower": -100,
      "tick_upper": 100,
      "expected_amount_a": 9999541,
      "expected_amount_b": 0,
      "tolerance_abs": 50
    },
    {
      "description": "A7: price exactly at upper bound -> falls into above-range branch (sqrt_price >= sqrt_upper)",
      "liquidity": 1000000000,
      "tick_current": 100,
      "tick_lower": -100,
      "tick_upper": 100,
      "expected_amount_a": 0,
      "expected_amount_b": 9999541,
      "tolerance_abs": 50
    }
  ],
