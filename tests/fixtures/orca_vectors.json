{
  "_comment": "Golden reference vectors for tick-liq CLMM math (F9). See docs/math-validation.md for derivation and regeneration.",
  "amounts_vectors": [
    {
      "description": "A1: zero liquidity -> both amounts zero",
      "liquidity": 0,
      "tick_current": 0,
