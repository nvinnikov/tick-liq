# Solana RPC endpoint (mainnet or devnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgres://tick:tick@localhost:5432/tick_liq

# LP Inspector keypair — base58-encoded private key (NEVER commit the real value)
LP_INSPECTOR_KEYPAIR=

# Logging level: trace | debug | info | warn | error
RUST_LOG=info
